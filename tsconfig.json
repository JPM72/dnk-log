{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "es2022",
		"allowJs": true,
		"resolveJsonModule": true,
		"moduleDetection": "force",
		"isolatedModules": true,
		"moduleResolution": "bundler",
		"module": "preserve",
		"noEmit": true,
		"noImplicitAny": false,
		"allowUmdGlobalAccess": true,
		"lib": ["es2022"],
		"types": [
			"node"
		]
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules"]
}
